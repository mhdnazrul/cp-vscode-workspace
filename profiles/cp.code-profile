  "name": "Competitive Programming",
  "settings": "{\n  \"editor.formatOnSave\": false,\n  \"editor.formatOnType\": false,\n  \"[cpp]\": {\n    \"editor.defaultFormatter\": null,\n    \"editor.formatOnSave\": false\n  },\n  \"code-runner.executorMap\": {\n    \"cpp\": \"g++ -std=c++17 -O2 $fileName -o $fileNameWithoutExt && ./$fileNameWithoutExt\"\n  },\n  \"cph.general.defaultLanguage\": \"cpp\",\n  \"cph.general.defaultLanguageTemplateFileLocation\": \"${userHome}/.config/vscode-cp/template.cpp\",\n  \"C_Cpp.default.cppStandard\": \"c++17\",\n  \"C_Cpp.formatting\": \"disabled\",\n  \"C_Cpp.clang_format_style\": \"Visual Studio\",\n  \"C_Cpp.clang_format_fallbackStyle\": \"none\",\n  \"C_Cpp.codeAnalysis.clangTidy.codeAction.formatFixes\": false\n}",
