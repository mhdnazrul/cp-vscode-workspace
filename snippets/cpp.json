  "GCD": {
    "prefix": "gcd",
    "body": "int gcd(int a, int b) {\n  return b ? gcd(b, a % b) : a;\n}",
    "description": "Euclidean GCD"
  },
  "LCM": {
    "prefix": "lcm",
    "body": "int lcm(int a, int b) {\n  return a / gcd(a, b) * b;\n}",
    "description": "Least Common Multiple"
  },
  "Binary exponentiation": {
    "prefix": "binpow",
    "body": "long long binpow(long long a, long long b) {\n  long long res = 1;\n  while (b > 0) {\n    if (b & 1) res = res * a;\n    a = a * a;\n    b >>= 1;\n  }\n  return res;\n}",
    "description": "Binary exponentiation"
  },
  "Solve function": {
    "prefix": "solve",
    "body": "void solve() {\n  $0\n}",
    "description": "Main solve function"
  },
  "Main skeleton": {
